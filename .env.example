# Marvin cxcalc API — 环境变量配置
# 复制此文件为 .env 并根据实际环境修改

# --- 服务配置 ---
SERVER_HOST=0.0.0.0
SERVER_PORT=8111
DEBUG=false

# --- VirtualBox VM 配置 ---
VM_NAME=Win11VM
VM_USERNAME=marvin-box
VM_PASSWORD=123123

# --- 路径配置 ---
# 宿主机上的共享文件夹路径
SHARED_FOLDER_HOST=/home/data/vbox_shared
# VM 内共享文件夹驱动器
SHARED_FOLDER_VM=Y:\
# VirtualBox VMs 目录 (通常在用户 home 下)
VBOX_USER_HOME=~/VirtualBox VMs

# --- cxcalc 配置 ---
CXCALC_PATH=C:\Progra~2\ChemAxon\MarvinBeans\bin\cxcalc.bat
COMMAND_TIMEOUT=600

# --- 容器行为 ---
# 容器启动时是否自动启动 VM
AUTO_START_VM=true
